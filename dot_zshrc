#======== Zoxide + FZF 集成 ==========
# Zoxide 是一个智能目录跳转工具，基于频率和最近使用
# FZF 提供模糊搜索和预览功能
# Eza 是 ls 的现代替代品，支持图标和 Git 状态

# 配置 Zoxide 使用 FZF 进行交互式目录选择
export _ZO_FZF_OPTS="
    --height=50%                    # 预览窗口高度
    --layout=reverse                # 反向布局（最新结果在顶部）
    --border                        # 显示边框
    --preview 'eza --tree --level=1 --color=always --icons=always {2} | head -200'  # 目录预览
    --preview-window=right:50%      # 预览窗口位置和大小
    --prompt='🚀 Jump to > '        # 提示符
"
eval "$(zoxide init zsh)"          # 初始化 Zoxide
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh  # 加载 FZF 配置

# zj: Zoxide 交互式跳转（避免与 zinit 的 `zi` 命令冲突）
# 用法: zj notes  # 交互式搜索并跳转到包含 "notes" 的目录
zj() {
    local dir
    dir="$(zoxide query -i -- "$@")" || return
    cd "$dir" || return
}

