#======== Direnv ==========
# Direnv 根据当前目录自动加载/卸载环境变量
# 非常适合项目级别的环境配置
eval "$(direnv hook zsh)"

#======== Docker ==========
# Docker Desktop 提供的初始化脚本
[ -f /Users/fengh/.docker/init-zsh.sh ] && source /Users/fengh/.docker/init-zsh.sh

#======== Conda（Miniforge） ==========
# Conda 是 Python/R 等科学计算包的管理器
# Miniforge 是 Conda 的轻量级版本
__conda_setup="$('/opt/homebrew/Caskroom/miniforge/base/bin/conda' 'shell.zsh' 'hook' 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
else
    if [ -f "/opt/homebrew/Caskroom/miniforge/base/etc/profile.d/conda.sh" ]; then
        . "/opt/homebrew/Caskroom/miniforge/base/etc/profile.d/conda.sh"
    else
        export PATH="/opt/homebrew/Caskroom/miniforge/base/bin:$PATH"
    fi
fi
unset __conda_setup

#======== X-cmd ==========
# X-cmd 是一个强大的包管理器和工具集合
[ ! -f "$HOME/.x-cmd.root/X" ] || . "$HOME/.x-cmd.root/X"

#======== JINA CLI（仅交互式 Shell） ==========
# JINA 是一个 AI 框架，提供命令行工具
if [[ -o interactive ]]; then
    compctl -K _jina jina

    _jina() {
        local words completions
        read -cA words

        if [ "${#words}" -eq 2 ]; then
            completions="$(jina commands)"
        else
            completions="$(jina completions ${words[2,-2]})"
        fi

        reply=(${(ps:\n:)completions})
    }
fi

