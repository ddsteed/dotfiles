#======== 颜色打印函数（已修复 Bug） ==========
# printc: 打印带背景色和前景色的文本
# 用法: printc <背景色> <前景色> <文本>
# 示例: printc red black "警告信息"
# 支持的颜色: black, red, green, yellow, blue, purple, skyblue, white
printc() {
    typeset -A bcolor fcolor
    fcolor=([black]=30 [red]=31 [green]=32 [yellow]=33 [blue]=34 [purple]=35 [skyblue]=36 [white]=37)
    # 注意: 黄色背景必须是 43，蓝色是 44（原配置错误，已修复）
    bcolor=([black]=40 [red]=41 [green]=42 [yellow]=43 [blue]=44 [purple]=45 [skyblue]=46 [white]=47)
    local txt=$3
    echo -e "\033[${bcolor[$1]};${fcolor[$2]}m${txt}\033[0m"
}

# printc_d: 打印调试信息（绿色前景，红色背景）
printc_d() {
    printc green red $1
}

