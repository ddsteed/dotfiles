#---------------------------------------------------------------------------------------------------
# 第一部分:Shell 框架初始化
#---------------------------------------------------------------------------------------------------
# 本部分负责:
#   - 加载 oh-my-zsh 框架
#   - 配置 zinit 插件管理器
#   - 初始化 powerlevel10k 主题
#   - 设置命令补全系统
#---------------------------------------------------------------------------------------------------

zmodload zsh/zprof  # 性能分析工具（可选，用于诊断启动速度问题）

#======== Oh-my-zsh 配置 ==========
# Oh-my-zsh 是一个流行的 zsh 配置框架，提供丰富的插件和主题
ZSH=$HOME/.oh-my-zsh
zstyle ':omz:update' mode auto  # 自动更新模式
alias zshup='omz update'         # 快捷命令: 更新 oh-my-zsh

#======== Zinit - 快速插件管理器 ==========
# Zinit 是一个轻量级、快速的插件管理器，可以显著加速 zsh 启动
# 相比传统的 oh-my-zsh 插件加载方式，zinit 使用异步加载和并行编译
source ~/.zinit/bin/zinit.zsh

#======== Powerlevel10k 即时提示符 ==========
# Powerlevel10k 是一个高性能的 zsh 主题，提供即时提示符功能
# 即时提示符可以在加载完整配置之前立即显示提示符，提升用户体验
# 这段代码必须保持在文件顶部，在需要用户输入的初始化代码之前
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

#======== 插件配置 ==========
# 加载以下插件:
#   - git:          Git 命令别名和补全
#   - macos:        macOS 特定命令
#   - autojump:     智能目录跳转（通过 j 命令）
#   - zsh-autosuggestions: 自动建议历史命令
#   - zsh-syntax-highlighting: 语法高亮
plugins=(git macos autojump zsh-autosuggestions zsh-syntax-highlighting)
source $ZSH/oh-my-zsh.sh

#======== Autojump（如通过 brew 安装） ==========
# Autojump 记录你访问的目录，允许通过 j <目录名> 快速跳转
# 例如: cd ~/Documents/RDS/NOTES 后，可以使用 j NOTES 跳转
[ -f /opt/homebrew/etc/profile.d/autojump.sh ] && . /opt/homebrew/etc/profile.d/autojump.sh

#======== 语法高亮（显式加载） ==========
# 命令行语法高亮，有效命令显示为绿色，无效命令显示为红色
source ~/.oh-my-zsh/custom/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

#======== Powerlevel10k 主题配置 ==========
# 要自定义提示符，运行: p10k configure
# 或直接编辑: ~/.p10k.zsh
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
typeset -g POWERLEVEL9K_INSTANT_PROMPT=quiet  # 安静模式，减少启动噪音
source ~/.oh-my-zsh/custom/themes/powerlevel10k/powerlevel10k.zsh-theme
ZSH_THEME="powerlevel10k/powerlevel10k"

#======== 补全系统（单次初始化，避免重复） ==========
# 智能缓存策略: 只在缓存过期时重建，否则使用快速加载
# 这样可以将启动时间减少 30-50%
autoload -Uz compinit
# 只在补全缓存不存在时创建
if [[ -n ${ZSH_COMPDUMP:+1} && ! -f $ZSH_COMPDUMP ]]; then
    compinit
# 只在缓存超过 24 小时时重建
elif [[ $(date +'%j') != $(stat -f '%Sm' -t '%j' $ZSH_COMPDUMP 2>/dev/null || stat -c '%y' $ZSH_COMPDUMP 2>/dev/null | cut -d' ' -f1 | cut -d'-' -f3) ]]; then
    compinit
# 否则使用缓存快速加载
else
    compinit -C
fi

