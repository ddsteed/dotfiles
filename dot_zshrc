#======== 语言环境设置 ==========
# 统一使用 UTF-8 编码，确保中文等非 ASCII 字符正常显示
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

#======== Homebrew（主 PATH，只设置一次） ==========
# Homebrew 是 macOS 上最流行的包管理器
# 将其放在 PATH 最前面，确保优先使用 brew 安装的版本
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:$PATH"

#======== GNU Coreutils（如通过 brew 安装） ==========
# macOS 的默认工具是 BSD 版本，GNU 工具提供了更多功能和更好的兼容性
# 这会提供 GNU 版本的 ls、cat、chmod 等工具
if brew list | grep coreutils > /dev/null 2>&1; then
    PATH="$(brew --prefix coreutils)/libexec/gnubin:$PATH"
    alias ls='ls -F --color=auto'  # 彩色 ls 输出
    eval "$(gdircolors -b $HOME/.dir_colors)"  # 加载目录颜色配置
fi

#======== 其他 PATH 添加（按类别分组） ==========
