#======== 进程管理函数 ==========
# pscom: 查找并列出匹配的进程
pscom() {
    ps -ef | grep "$1" | grep -v grep
    local pid=$(ps -ef | grep "$1" | grep -v grep | awk '{print $2}')
    echo $pid
}

# stop: 强制终止匹配的进程
stop() {
    pid=($(ps -ef | grep "$1" | grep -v grep | awk '{print $2}'))
    for p ($pid) {
        kill -9 $p
    }
}

