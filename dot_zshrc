#======== Yazi（终端文件管理器） ==========
# Yazi 是一个用 Rust 编写的极速终端文件管理器
# 支持预览、标签页、大量插件
function y() {
    local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
    yazi "$@" --cwd-file="$tmp"
    IFS= read -r -d '' cwd < "$tmp"
    [ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && builtin cd -- "$cwd"
    rm -f -- "$tmp"
}

